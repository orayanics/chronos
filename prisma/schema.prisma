generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum POMODORO_TYPE {
  WORK
  SHORT
  LONG
}

model SessionLog {
  id             Int           @id @default(autoincrement())
  type           POMODORO_TYPE
  duration       Int
  completedAt    DateTime      @default(now())
  sessionStateId Int
  sessionState   SessionState  @relation(fields: [sessionStateId], references: [id], onDelete: Cascade)
}

model Task {
  id             Int           @id @default(autoincrement())
  text           String
  completed      Boolean       @default(false)
  sessionStateId Int
  sessionState   SessionState  @relation(fields: [sessionStateId], references: [id], onDelete: Cascade)
}

model Settings {
  id                    Int      @id
  workMinutes           Int      @default(25)
  shortBreakMinutes     Int      @default(5)
  longBreakMinutes      Int      @default(15)
  cyclesBeforeLongBreak Int      @default(4)
  autoStartBreaks       Boolean  @default(false)
  autoStartPomodoros    Boolean  @default(false)
}

model SessionState {
  id                   Int            @id
  startedAt            Int            @default(0)
  currentMode          POMODORO_TYPE  @default(WORK)
  pomodorosCompleted   Int            @default(0)
  shortBreaksCompleted Int            @default(0)
  longBreaksCompleted  Int            @default(0)
  currentCycleCount    Int            @default(0)
  logs                 SessionLog[]
  tasks                Task[]
}
