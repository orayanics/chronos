generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// Database Schema for a Pomodoro Timer Application
// Contains pomodoro sessions and tasks

model PSession {
  id        Int      @id @default(autoincrement())
  startTime DateTime
  endTime   DateTime
  taskId    Int
  task      PTask     @relation(fields: [taskId], references: [id])
}

model PTask {
  id          Int        @id @default(autoincrement())
  title       String
  description String?
  sessions    PSession[]
}

enum LogType {
  WORK
  SHORT
  LONG
}

model SLog {
  id Int @id @default(autoincrement())
  type LogType
  duration Int // Duration in seconds
}